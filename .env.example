# Local dev overrides for the Supabase client (optional).
# The app ships with safe public defaults baked into src/lib/supabaseConfig.ts,
# so you only need this file if you want to point at a different project.
#
# These two values are PUBLIC (the publishable/anon key is protected by RLS)
# and safe to expose in the browser. NEVER put the service-role key, the
# Anthropic key, or any other secret here — those live only in Supabase Edge
# Function secrets (see docs/PHASE2_SETUP.md).
VITE_SUPABASE_URL=https://stkfdavpjflpqoxjunnj.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xeEuhqPfkxt9wF0PyRKfzg_kRx9S-Hv
