# pnpm configuration — supply-chain & reliability guardrails.
#
# minimum-release-age: don't install a package version until it has been
# public for at least this many minutes (1440 = 24h). Defends against
# hijacked/compromised releases that are usually yanked within hours.
minimum-release-age=1440

# Verify the integrity hash of every package in the content-addressable
# store on each install (default true; set explicitly for clarity).
verify-store-integrity=true

# Fail the install if the local pnpm version doesn't satisfy the
# "packageManager" field in package.json (deterministic builds).
package-manager-strict=true
